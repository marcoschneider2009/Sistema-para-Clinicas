<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<main class="content-wrapper">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <div>
            <h1><i class="fas fa-users"></i> Gestão de Pacientes</h1>
            <p>Lista de pacientes cadastrados no sistema.</p>
        </div>
        
        <div style="flex: 1; margin: 0 30px;">
            <div style="position: relative;">
                <i class="fas fa-search" style="position: absolute; left: 12px; top: 12px; color: #94a3b8;"></i>
                <input type="text" id="inputPesquisa" onkeyup="filtrarClientes()" placeholder="Pesquisar paciente pelo nome..." 
                       style="width: 100%; padding: 10px 10px 10px 40px; border: 1px solid #e2e8f0; border-radius: 8px;">
            </div>
        </div>

        <button class="btn-salvar" onclick="abrirModalCadastro()" style="background: #1e293b; color: white; padding: 12px 24px; border-radius: 6px; cursor: pointer; border: none;">
            <i class="fas fa-plus"></i> Novo Paciente
        </button>
    </div>

    <table class="aura-table" id="tabelaClientes">
        <thead>
            <tr>
                <th style="width: 50px;">Foto</th> <th>Nome do Paciente</th>
                <th>CPF</th>
                <th>Telefone</th>
                <th style="text-align: center;">Ações</th>
            </tr>
        </thead>
        <tbody>
            <% if (clientes && clientes.length > 0) { %>
                <% clientes.forEach(cliente => { %>
                    <tr>
                        <td>
                            <img src="/uploads/clientes/<%= cliente.foto || 'default-avatar.png' %>" 
                                 style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid #e2e8f0;">
                        </td>
                        <td class="cliente-nome"><strong><%= cliente.nome %></strong></td>
                        <td><%= cliente.cpf %></td>
                        <td><%= cliente.telefone %></td>
                        
                        <td style="text-align: center; white-space: nowrap;">
                        <a href="/clientes/editar/<%= cliente.id %>" class="btn-edit" title="Ver Ficha / Editar" style="margin-right: 10px; text-decoration: none; color: #0284c7;">
                        <i class="fas fa-user-md"></i>
                        </a>

                    <button type="button" class="btn-delete-compact" title="Excluir" 
                    onclick="abrirModalExcluir('<%= cliente.id %>', '<%= cliente.nome %>')"
                    style="background: none; border: none; cursor: pointer; color: #ef4444;">
                   <i class="fas fa-trash-alt"></i>
                   </button>
                   </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="text-align: center; padding: 40px;">Nenhum paciente encontrado.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</main>

<div id="modalCadastro" class="modal-overlay" style="display: none;">
    <div class="modal-content" style="max-width: 600px;">
        <h2 style="margin-bottom: 20px;"><i class="fas fa-user-plus"></i> Novo Cadastro</h2>
        
        <form action="/clientes/novo" method="POST" enctype="multipart/form-data">
            
            <div style="display: flex; gap: 20px; margin-bottom: 15px;">
                <div style="flex: 1;">
                    <label style="display: block; margin-bottom: 5px;">Foto do Paciente</label>
                    <input type="file" name="foto" accept="image/*" style="width: 100%; padding: 7px; border: 1px solid #ddd; border-radius: 4px;">
                </div>
                <div style="flex: 2;">
                    <label style="display: block; margin-bottom: 5px;">Nome Completo</label>
                    <input type="text" name="nome" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                </div>
            </div>

            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                <div style="flex: 1;">
                    <label style="display: block; margin-bottom: 5px;">CPF</label>
                    <input type="text" name="cpf" placeholder="000.000.000-00" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                </div>
                <div style="flex: 1;">
                    <label style="display: block; margin-bottom: 5px;">Nascimento</label>
                    <input type="date" name="data_nascimento" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                </div>
            </div>

            <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px;">Telefone</label>
                <input type="text" name="telefone" placeholder="(00) 00000-0000" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
            </div>

            <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px;">Histórico Clínico / Observações</label>
                <textarea name="historico" rows="3" placeholder="Antecedentes, alergias ou notas iniciais..." 
                          style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-family: inherit;"></textarea>
            </div>

            <div style="display: flex; gap: 10px; margin-top: 20px;">
                <button type="submit" style="flex: 1; background: #1e293b; color: white; padding: 12px; border: none; border-radius: 4px; cursor: pointer;">Salvar Cadastro</button>
                <button type="button" onclick="fecharModalCadastro()" style="flex: 1; background: #e2e8f0; padding: 12px; border: none; border-radius: 4px; cursor: pointer;">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<div id="modalExcluir" class="modal-overlay" style="display: none;">
    <div class="modal-content" style="max-width: 400px; text-align: center;">
        <div style="color: #ef4444; font-size: 3rem; margin-bottom: 15px;">
            <i class="fas fa-exclamation-circle"></i>
        </div>
        <h2>Confirmar Exclusão</h2>
        <p id="textoConfirmacao" style="margin: 15px 0; color: #64748b;"></p>
        <form id="formExcluir" method="POST">
            <div style="display: flex; gap: 10px; margin-top: 25px;">
                <button type="submit" style="flex: 1; background: #ef4444; color: white; padding: 12px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold;">Sim, Excluir</button>
                <button type="button" onclick="fecharModalExcluir()" style="flex: 1; background: #e2e8f0; padding: 12px; border: none; border-radius: 6px; cursor: pointer;">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<script>
    // FUNÇÃO DE PESQUISA DINÂMICA
    function filtrarClientes() {
        const input = document.getElementById('inputPesquisa').value.toLowerCase();
        const rows = document.querySelectorAll('#tabelaClientes tbody tr');

        rows.forEach(row => {
            const nomeCell = row.querySelector('.cliente-nome');
            if (nomeCell) {
                const nomeText = nomeCell.textContent.toLowerCase();
                row.style.display = nomeText.includes(input) ? '' : 'none';
            }
        });
    }

    function abrirModalCadastro() { document.getElementById('modalCadastro').style.display = 'flex'; }
    function fecharModalCadastro() { document.getElementById('modalCadastro').style.display = 'none'; }

    function abrirModalExcluir(id, nome) {
        document.getElementById('modalExcluir').style.display = 'flex';
        document.getElementById('textoConfirmacao').innerHTML = `Tem certeza que deseja excluir o paciente <strong>${nome}</strong>?`;
        document.getElementById('formExcluir').action = `/clientes/deletar/${id}`;
    }

    function fecharModalExcluir() { document.getElementById('modalExcluir').style.display = 'none'; }
</script>

<%- include('partials/footer') %>